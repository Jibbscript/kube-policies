# Build artifacts
dist/
build/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage*.out
coverage*.html

# Dependency directories
vendor/

# Go workspace file
go.work

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
*.log

# Kubernetes test artifacts
test-results/
benchmark-results.txt
helm-template-output.yaml

# Environment files
.env
.env.local
.env.*.local

# Docker
.dockerignore

# Helm packaged-chart artifacts at the chart root.
charts/*.tgz
# Helm subchart dependency cache (auto-fetched by `helm dep update`).
charts/*/charts/

# oh-my-claudecode + Claude Code runtime state (not source).
.omc/
web/.omc/
.claude/

# Dashboard build-time SPA copy — managed by `make build-dashboard`.
# The .placeholder file is committed so //go:embed all:web_dist stays valid
# before the first SPA build has run.
cmd/dashboard/web_dist/*
!cmd/dashboard/web_dist/.placeholder

# Built SPA artifacts (T3 owns web/, dist is build output).
web/dist/
web/node_modules/
web/playwright-report/
web/test-results/

# Stray `go build ./cmd/dashboard` output left in the repo root.
/dashboard

# demo pipeline outputs
demo/remotion/node_modules/
demo/remotion/out/
demo/dist/
demo/capture/.kind-state/
