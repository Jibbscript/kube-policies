{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Jibbscript/kube-policies/demo/remotion/manifest.schema.json",
  "title": "KubePoliciesDemoCaptureManifest",
  "description": "Capture-pipeline manifest contract. Every asset the Remotion composition references must appear here with provenance (sha256, anchor_commit) so verify.sh can prove the composition is rendering the asset it was authored against.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "anchor_commit",
    "captured_at",
    "screenshots",
    "terminals",
    "audit",
    "masks_applied"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "anchor_commit": {
      "type": "string",
      "description": "Short git SHA the capture was run against.",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "captured_at": {
      "type": ["string", "null"],
      "description": "RFC3339 UTC timestamp the capture pipeline finished, or null for the unfilled stub.",
      "format": "date-time"
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "expected_width", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "expected_width": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "expected_content_region": { "$ref": "#/definitions/contentRegion" },
          "expected_content_regions_extra": {
            "type": "array",
            "items": { "$ref": "#/definitions/contentRegion" },
            "description": "Additional crop regions for PNGs that are referenced by more than one ScreenshotPanel in the scene (e.g. Tile 1 + Tile 3 both crop dashboard-livedecisions.png)."
          }
        }
      }
    },
    "terminals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "audit": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "masks_applied": {
      "type": "array",
      "description": "Audit trail of capture-time DOM masks (Principle 4).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mask_name", "css_selector", "fixed_value", "applied_at_url"],
        "properties": {
          "mask_name": { "type": "string" },
          "css_selector": { "type": "string" },
          "fixed_value": { "type": "string" },
          "applied_at_url": { "type": "string", "format": "uri" }
        }
      }
    }
  },
  "definitions": {
    "contentRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height", "description"],
      "description": "Normalized 0..1 rectangle identifying the region of the PNG that a scene's ScreenshotPanel.crop is anchored to. Tied to the parent artifact's sha256 — when the sha256 changes, every consumer must reconfirm the rect is still meaningful (US-6 of dashboard-500-fix).",
      "properties": {
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 },
        "width": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "height": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "description": { "type": "string" }
      }
    }
  }
}
