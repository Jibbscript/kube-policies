{
  "apiVersion": "v1",
  "kind": "Pod",
  "metadata": {
    "name": "hostpath-pod",
    "namespace": "default"
  },
  "spec": {
    "containers": [
      {
        "name": "app",
        "image": "nginx:1.27.0",
        "volumeMounts": [{ "name": "logs", "mountPath": "/var/log/host" }]
      }
    ],
    "volumes": [
      {
        "name": "logs",
        "hostPath": { "path": "/var/log" }
      }
    ]
  }
}
